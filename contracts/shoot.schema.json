{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://finaltheoryofeverything.org/orrery/contracts/shoot.schema.json",
  "title": "shoot --json output envelope",
  "description": "Machine-checkable schema for the shoot tool's --json output. Matches contracts/shoot.contract.md v1.0.0.",
  "type": "object",
  "additionalProperties": false,
  "required": ["tool", "version", "seed", "params", "result", "verdict", "gates", "notes"],
  "properties": {
    "tool": { "const": "shoot" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "seed": { "type": "integer", "minimum": 0 },
    "params": {
      "type": "object",
      "additionalProperties": false,
      "required": ["potential", "levels", "xmax", "length", "steps", "tol"],
      "properties": {
        "potential": { "type": "string", "enum": ["harmonic", "square"] },
        "levels": { "type": "integer", "minimum": 1, "maximum": 64 },
        "xmax": { "type": "number", "exclusiveMinimum": 0.0 },
        "length": { "type": "number", "exclusiveMinimum": 0.0 },
        "steps": { "type": "integer", "minimum": 100, "maximum": 4000000 },
        "tol": { "type": "number", "minimum": 0.0 }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["potential", "levels", "xmax", "length", "steps",
                   "eigenvalues", "oracles", "rel_errs", "max_rel_err", "node_counts"],
      "properties": {
        "potential": { "type": "string", "enum": ["harmonic", "square"] },
        "levels": { "type": "integer", "minimum": 1 },
        "xmax": { "type": "number" },
        "length": { "type": "number" },
        "steps": { "type": "integer" },
        "eigenvalues": { "type": "array", "items": { "type": "number" }, "minItems": 1 },
        "oracles": { "type": "array", "items": { "type": "number" }, "minItems": 1 },
        "rel_errs": { "type": "array", "items": { "type": "number", "minimum": 0.0 }, "minItems": 1 },
        "max_rel_err": { "type": "number", "minimum": 0.0 },
        "node_counts": { "type": "array", "items": { "type": "integer", "minimum": 0 }, "minItems": 1 }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "fired", "value", "threshold"],
        "properties": {
          "id": { "type": "string", "enum": ["G-ORACLE-MISMATCH"] },
          "fired": { "type": "boolean" },
          "value": { "type": "number" },
          "threshold": { "type": "number" }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
