{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://finaltheoryofeverything.org/orrery/contracts/algebra.schema.json",
  "title": "algebra --json output envelope",
  "description": "Machine-checkable schema for the algebra tool's --json output. Matches contracts/algebra.contract.md v1.0.0.",
  "type": "object",
  "additionalProperties": false,
  "required": ["tool", "version", "seed", "params", "result", "verdict", "gates", "notes"],
  "properties": {
    "tool": { "const": "algebra" },
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "seed": { "type": "integer", "minimum": 0 },
    "params": {
      "type": "object",
      "additionalProperties": false,
      "required": ["regime", "mass2", "max_size", "num_sizes", "fit_points", "tol"],
      "properties": {
        "regime": { "type": "string", "enum": ["critical", "massive"] },
        "mass2": { "type": "number" },
        "max_size": { "type": "integer", "minimum": 32, "maximum": 4096 },
        "num_sizes": { "type": "integer", "minimum": 3, "maximum": 12 },
        "fit_points": { "type": "integer", "minimum": 2, "maximum": 12 },
        "tol": { "type": "number", "minimum": 0.0, "maximum": 1.0 }
      }
    },
    "result": {
      "type": "object",
      "additionalProperties": false,
      "required": ["regime", "c_expected", "c_measured", "c_error", "slope_nats", "growth_nats",
                   "divergent", "min_size", "max_size", "s_at_max_bits"],
      "properties": {
        "regime": { "type": "string", "enum": ["critical", "massive"] },
        "c_expected": { "type": "number" },
        "c_measured": { "type": "number" },
        "c_error": { "type": "number", "minimum": 0.0 },
        "slope_nats": { "type": "number" },
        "growth_nats": { "type": "number" },
        "divergent": { "type": "boolean" },
        "min_size": { "type": "integer" },
        "max_size": { "type": "integer" },
        "s_at_max_bits": { "type": "number" }
      }
    },
    "verdict": { "type": "string", "enum": ["pass", "fail"] },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "fired", "value", "threshold"],
        "properties": {
          "id": { "type": "string", "enum": ["G-WRONG-C"] },
          "fired": { "type": "boolean" },
          "value": { "type": "number" },
          "threshold": { "type": "number" }
        }
      }
    },
    "notes": { "type": "string" }
  }
}
