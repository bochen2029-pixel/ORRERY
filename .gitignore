# Build artifacts (the code is ephemeral; source + contract + golden are load-bearing)
*.exe
*.obj
*.lib
*.exp
*.pdb
*.ilk
*.o
*.a

# Scratch / large run outputs (declared goldens are committed explicitly)
*.tmp
scratch/
*.csv.big
tools/**/_*.txt
tools/**/_*.json
tools/**/_*.csv

# Editor
.vs/
*.swp

# Python
__pycache__/
*.pyc
